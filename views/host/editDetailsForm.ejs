<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Home</title>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600 text-[#243142] antialiased">
    <header class="px-4 py-4">
        <%- include(`../partials/nav`) %>
    </header>
    <main class="max-w-2xl mx-auto my-8 p-7 bg-white rounded-xl shadow-2xl">
        <h1 class="text-2xl font-semibold mb-6 text-center">Edit Your Home Details</h1>
        <form action="/host/edit/<%=home._id%>" method="POST" class="grid gap-6">
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label for="houseName" class="block text-sm font-semibold text-[#243142] uppercase mb-2">House Name</label>
                    <input value="<%=home.houseName%>" required type="text" placeholder="Enter House Name" name="houseName" id="houseName" class="w-full px-4 py-3 border border-gray-200 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-300">
                </div>
                <div>
                    <label for="email" class="block text-sm font-semibold text-[#243142] uppercase mb-2">Email</label>
                    <input value="<%=home.email%>" required type="email" placeholder="Enter your email" name="email" id="email" class="w-full px-4 py-3 border border-gray-200 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-300">
                </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label for="price" class="block text-sm font-semibold text-[#243142] uppercase mb-2">Price Per Night</label>
                    <input value="<%=home.price%>" required type="number" placeholder="Enter Price per night" name="price" id="price" class="w-full px-4 py-3 border border-gray-200 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-300">
                </div>
                <div>
                    <label for="location" class="block text-sm font-semibold text-[#243142] uppercase mb-2">Location</label>
                    <input value="<%=home.location%>" required type="text" placeholder="Enter Location" name="location" id="location" class="w-full px-4 py-3 border border-gray-200 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-300">
                </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 items-end">
                <div>
                    <label for="rating" class="block text-sm font-semibold text-[#243142] uppercase mb-2">Rating (0-10)</label>
                    <input value="<%=home.rating%>" type="range" min="0" max="10" placeholder="Rating" name="rating" id="rating" class="w-full">
                </div>
                <div>
                    <label for="imageUrl" class="block text-sm font-semibold text-[#243142] uppercase mb-2">Image URL</label>
                    <input value="<%=home.imageUrl%>" required type="url" placeholder="Enter image URL" name="imageUrl" id="imageUrl" class="w-full px-4 py-3 border border-gray-200 rounded-md bg-gray-50 focus:outline-none focus:ring-2 focus:ring-indigo-300">
                </div>
            </div>
            <div>
                <input type="submit" value="Update Details" class="w-full px-4 py-3 bg-indigo-500 text-white rounded-md font-semibold hover:opacity-90 transition">
            </div>
        </form>
    </main>
</body>
</html>
