<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Home</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white antialiased m-0 pt-20">
    <header class="py-0">
        <%- include(`../partials/nav`,{currentPage}) %>
    </header>
    <main class="max-w-2xl mx-auto my-8 p-7 bg-white/10 backdrop-blur-xl rounded-2xl shadow-2xl shadow-black/50 border border-white/10">
        <h1 class="text-3xl font-bold mb-8 text-center text-white">Edit Your Home Details</h1>
        <form action="/host/edit/<%=home._id%>" method="POST" class="grid gap-6">
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label for="houseName" class="block text-sm font-semibold text-white uppercase mb-2">House Name</label>
                    <input value="<%=home.houseName%>" required type="text" placeholder="Enter House Name" name="houseName" id="houseName" class="w-full px-4 py-3 border border-white/20 rounded-lg bg-white/10 text-white placeholder-white/50 focus:outline-none focus:border-sky-400/50 focus:ring-2 focus:ring-sky-400/20 transition duration-200">
                </div>
                <div>
                    <label for="email" class="block text-sm font-semibold text-white uppercase mb-2">Email</label>
                    <input value="<%=home.email%>" required type="email" placeholder="Enter your email" name="email" id="email" class="w-full px-4 py-3 border border-white/20 rounded-lg bg-white/10 text-white placeholder-white/50 focus:outline-none focus:border-sky-400/50 focus:ring-2 focus:ring-sky-400/20 transition duration-200">
                </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2">
                <div>
                    <label for="price" class="block text-sm font-semibold text-white uppercase mb-2">Price Per Night</label>
                    <input value="<%=home.price%>" required type="number" placeholder="Enter Price per night" name="price" id="price" class="w-full px-4 py-3 border border-white/20 rounded-lg bg-white/10 text-white placeholder-white/50 focus:outline-none focus:border-sky-400/50 focus:ring-2 focus:ring-sky-400/20 transition duration-200">
                </div>
                <div>
                    <label for="location" class="block text-sm font-semibold text-white uppercase mb-2">Location</label>
                    <input value="<%=home.location%>" required type="text" placeholder="Enter Location" name="location" id="location" class="w-full px-4 py-3 border border-white/20 rounded-lg bg-white/10 text-white placeholder-white/50 focus:outline-none focus:border-sky-400/50 focus:ring-2 focus:ring-sky-400/20 transition duration-200">
                </div>
            </div>
            <div class="grid gap-4 sm:grid-cols-2 items-end">
                <div>
                    <label for="rating" class="block text-sm font-semibold text-white uppercase mb-2">Rating (0-10)</label>
                    <input value="<%=home.rating%>" type="range" min="0" max="10" placeholder="Rating" name="rating" id="rating" class="w-full accent-sky-500">
                </div>
                <div>
                    <label for="imageUrl" class="block text-sm font-semibold text-white uppercase mb-2">Image URL</label>
                    <input value="<%=home.imageUrl%>" required type="url" placeholder="Enter image URL" name="imageUrl" id="imageUrl" class="w-full px-4 py-3 border border-white/20 rounded-lg bg-white/10 text-white placeholder-white/50 focus:outline-none focus:border-sky-400/50 focus:ring-2 focus:ring-sky-400/20 transition duration-200">
                </div>
            </div>
            <div>
                <input type="submit" value="Update Details" class="w-full px-4 py-3 bg-gradient-to-r from-sky-500 to-sky-600 hover:from-sky-400 hover:to-sky-500 text-white rounded-lg font-semibold transition duration-200 shadow-lg shadow-sky-500/30 cursor-pointer">
            </div>
        </form>
    </main>
</body>
</html>
