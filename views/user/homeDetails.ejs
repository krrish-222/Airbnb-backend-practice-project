<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home Details</title>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-indigo-500 to-purple-600 text-[#243142] antialiased">
    <header class="px-4 py-4">
        <%- include(`../partials/nav`,{currentPage}) %>
    </header>
    <main class="max-w-4xl mx-auto my-8 p-7 bg-white rounded-xl shadow-2xl">
        <h1 class="text-2xl font-semibold mb-6">Home Details</h1>
        <% if (hometoshow) { %>
            <div class="grid lg:grid-cols-2 gap-8 mt-5">
                <div class="bg-white rounded-lg overflow-hidden shadow-md">
                    <img class="w-full h-80 object-cover bg-gray-100" src="<%= hometoshow.imageUrl %>" alt="<%= hometoshow.houseName %>">
                </div>
                <div class="bg-white rounded-lg p-6 shadow-md">
                    <h2 class="text-xl font-semibold mb-4"><%= hometoshow.houseName %></h2>
                    <p class="text-gray-500 mb-4">A perfect stay in <strong class="text-[#243142]"><%= hometoshow.location %></strong>.</p>
                    <ul class="space-y-3">
                        <li class="bg-gray-100 rounded-md p-3 flex justify-between text-sm text-gray-600"><span>Price per night</span><strong class="text-[#243142]">₹<%= hometoshow.price %></strong></li>
                        <li class="bg-gray-100 rounded-md p-3 flex justify-between text-sm text-gray-600"><span>Rating</span><strong class="text-[#243142]"><%= hometoshow.rating %>/10</strong></li>
                        <li class="bg-gray-100 rounded-md p-3 flex justify-between text-sm text-gray-600"><span>Contact</span><strong class="text-[#243142]"><%= hometoshow.email %></strong></li>
                        <li class="bg-gray-100 rounded-md p-3 flex justify-between text-sm text-gray-600"><span>Home ID</span><strong class="text-[#243142]"><%= hometoshow._id %></strong></li>
                    </ul>
                    <div class="flex flex-wrap items-center justify-between gap-3 mt-6">
                        <a class="inline-block px-4 py-2 bg-indigo-500 text-white rounded-md font-semibold" href="/home">Back to homes</a>
                        <div><%- include(`../partials/favouriteButton`,{homeId:hometoshow._id}) %></div>
                    </div>
                </div>
            </div>
        <% } else { %>
            <p class="text-gray-500">Sorry, we could not find the selected home.</p>
            <a class="inline-block px-4 py-2 bg-indigo-500 text-white rounded-md mt-4" href="/home">Back to homes</a>
            <% } %>
    </main>
</body>