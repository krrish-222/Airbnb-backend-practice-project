<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to Homepage</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="min-h-screen bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white antialiased m-0 pt-20">
    
    <header class="py-0">
        <%- include(`../partials/nav`,{currentPage}) %>
    </header>
    <main class="max-w-4xl mx-auto my-8 p-7 bg-white/10 backdrop-blur-xl rounded-2xl shadow-2xl shadow-black/50 border border-white/10">
        <h1 class="text-3xl font-bold mb-8 text-white">Here are your registered homes</h1>
        <div class="grid gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            <% 
                allHomes.forEach((home)=>{%>
                    <div class="bg-white/10 backdrop-blur-lg rounded-xl overflow-hidden shadow-lg shadow-black/20 flex flex-col transition-all transform hover:-translate-y-1 hover:shadow-xl hover:bg-white/15 border border-white/10">
                        <img class="w-full h-40 object-cover bg-slate-700" src="<%=  home.imageUrl%>" alt="Home image">
                        <div class="p-4 flex flex-col flex-1">
                            <h2 class="text-lg font-semibold text-white mb-2"><%=  home.houseName%></h2>
                            <p class="text-white/70 text-sm">Email: <%=  home.email%></p>
                            <p class="text-white/70 text-sm">Price / night: ₹<%=  home.price%></p>
                            <p class="text-white/70 text-sm">Location: <%=  home.location%></p>
                            <p class="text-white/70 text-sm">Rating: <span class="text-sky-400 font-bold"><%=  home.rating%></span>/10</p>
                            <div class="flex gap-3 items-center justify-between mt-4 flex-wrap">
                                <a href="/home/<%= home._id%>" class="inline-flex items-center justify-center px-3 py-1.5 bg-sky-500 hover:bg-sky-400 text-white rounded-lg font-medium text-sm transition duration-200 cursor-pointer whitespace-nowrap">Details</a>
                                <div><%- include(`../partials/favouriteButton`,{homeId:home._id}) %></div>
                            </div>
                        </div>
                        
                    </div>
                <%})
            %>
        </div>
    </main>
</body>
</html>
